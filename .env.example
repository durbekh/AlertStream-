# ============================================
# AlertStream Environment Configuration
# ============================================

# Django
SECRET_KEY=your-very-long-secret-key-change-in-production
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# PostgreSQL
POSTGRES_DB=alertstream
POSTGRES_USER=alertstream
POSTGRES_PASSWORD=alertstream_secret
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# Celery
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/1

# Email Provider (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@alertstream.io

# SendGrid (alternative email provider)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Twilio (SMS & WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886

# Firebase Cloud Messaging (Push Notifications)
FCM_SERVER_KEY=AAAAxxxxxxxx:xxxxxxxxxxxxxxxxxxxx
FCM_PROJECT_ID=your-project-id

# Slack
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Frontend
REACT_APP_API_URL=http://localhost/api
REACT_APP_WS_URL=ws://localhost/ws

# Rate Limiting Defaults
DEFAULT_RATE_LIMIT_REQUESTS=1000
DEFAULT_RATE_LIMIT_WINDOW=3600

# Retry Configuration
MAX_RETRY_ATTEMPTS=5
RETRY_BACKOFF_BASE=60
RETRY_BACKOFF_MULTIPLIER=2

# Logging
LOG_LEVEL=INFO
